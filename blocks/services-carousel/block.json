{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "services/carousel",
    "version": "1.0.0",
    "title": "Services Carousel",
    "category": "widgets",
    "icon": "images-alt2",
    "description": "Display services in a configurable carousel.",
    "keywords": [
        "services",
        "carousel"
    ],
    "textdomain": "services-plugin",
    "supports": {
        "html": false
    },
    "attributes": {
        "number": {
            "type": "number",
            "default": 5
        },
        "order": {
            "type": "string",
            "default": "DESC"
        },
        "orderby": {
            "type": "string",
            "default": "date"
        },
        "category": {
            "type": "string",
            "default": ""
        },
        "minPrice": {
            "type": "number",
            "default": 0
        },
        "maxPrice": {
            "type": "number",
            "default": 0
        }
    },
    "editorScript": "file:./build/index.js",
    "editorStyle": "file:./build/index.css",
    "render": "file:./render.php"
}